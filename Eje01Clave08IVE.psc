Algoritmo sin_titulo
	//Entry
	Definir num Como Entero
	Escribir "Give whatever natural number: "
	Escribir "Dime un numero entero o natural: "
	leer num
	//Process
	si (num) >= 0 Entonces
		Escribir "Im positive number"
		Escribir "Soy un numero positivo"
	sino 
		Escribir "Im negative number"
		Escribir "Soy un numero negativo"
	FinSi
		si (num) == 0 Entonces
			Escribir "Im the infinite"
			Escribir "Soy el infinito"
		FinSi
	
FinAlgoritmo
